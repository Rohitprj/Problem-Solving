graph TB
    %% Start/Finish nodes default to a different color in base theme, 
    %% styling them explicitly to force the B&W look.
    START((Start))
    style START fill:#fff,stroke:#000,stroke-width:2px,color:#000
    
    PLAN["TASK: Project Planning<br/>DUR: 5 Days"]
    
    DB["TASK: MongoDB Setup<br/>DUR: 2 Days"]

    %% Backend Module Subgraph
    subgraph Development_Module [Backend & Tracking]
        direction TB
        AUTH["TASK: User Auth System<br/>DUR: 4 Days"]
        TRACK["TASK: Analytics Logic<br/>DUR: 3 Days"]
        CHAT_API["TASK: Chat History API<br/>DUR: 4 Days"]
    end

    %% AI Engine Subgraph
    subgraph AI_Engine [AI & Knowledge]
        direction TB
        KB["TASK: Knowledge Base / Books<br/>DUR: 7 Days"]
        NLP["TASK: LLM Integration<br/>DUR: 10 Days"]
        VOICE["TASK: Voice Query Support<br/>DUR: 6 Days"]
    end

    ADMIN["TASK: Admin Dashboard<br/>DUR: 8 Days"]
    TEST["TASK: System Testing<br/>DUR: 5 Days"]
    
    END((Finish))
    style END fill:#fff,stroke:#000,stroke-width:2px,color:#000

    %% Add default styling rules to all rectangles to be strict B&W
    classDef bw fill:#fff,stroke:#000,color:#000,stroke-width:1px;
    class PLAN,DB,AUTH,TRACK,CHAT_API,KB,NLP,VOICE,ADMIN,TEST bw;

    %% Connections
    START --> PLAN
    PLAN --> DB

    DB --> AUTH
    DB --> TRACK
    AUTH --> CHAT_API

    DB --> KB
    KB --> NLP
    NLP --> VOICE

    CHAT_API --> ADMIN
    TRACK --> ADMIN
    VOICE --> ADMIN

    ADMIN --> TEST
    TEST --> END