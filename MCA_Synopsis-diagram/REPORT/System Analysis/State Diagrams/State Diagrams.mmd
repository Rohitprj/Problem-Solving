stateDiagram-v2
    direction TB

    [*] --> App_Launched
    App_Launched --> Authentication

    state Authentication {
        [*] --> Login_Page
        Login_Page --> Signup_Page : New User
        Signup_Page --> Login_Page : Created
        Login_Page --> Dashboard : Valid
    }

    state Dashboard {
        direction LR
        Chat_Mode
        History_Mode
        Voice_Mode
        Profile_Mode
    }

    Dashboard --> Admin_Check : Admin
    Dashboard --> Logout_State : Exit

    state Chat_Mode {
        [*] --> Query
        Query --> AI_Proc
        AI_Proc --> Save
        Save --> [*]
    }

    state Voice_Mode {
        [*] --> Record
        Record --> STT
        STT --> AI_Proc
    }

    state Admin_Check {
        Verify --> Admin_DB : Yes
        Verify --> Dashboard : No
    }

    state Admin_DB {
        View_Users --> Monitor
        Monitor --> Reports
    }

    Logout_State --> End_App
    End_App --> [*]