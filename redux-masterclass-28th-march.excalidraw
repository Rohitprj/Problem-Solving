    {
      "id": "21vhEMnt8Qr9XGnSndE-o",
      "type": "text",
      "x": 571.2421875,
      "y": 976.625,
      "width": 708.3997802734375,
      "height": 525,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a4",
      "roundness": null,
      "seed": 1480405218,
      "version": 75,
      "versionNonce": 1728099234,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774699146859,
      "link": null,
      "locked": false,
      "text": "Problem Without Redux\n\n    In a normal React app:\n    \n     - State is stored in components\n     - You pass data via props (prop drilling)\n    \n    App → Parent → Child → DeepChild\n    \n    Problems:\n    \n    => Too much prop drilling\n    => State duplication in multiple places\n    => Hard to debug\n    => Components tightly coupled ",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Problem Without Redux\n\n    In a normal React app:\n    \n     - State is stored in components\n     - You pass data via props (prop drilling)\n    \n    App → Parent → Child → DeepChild\n    \n    Problems:\n    \n    => Too much prop drilling\n    => State duplication in multiple places\n    => Hard to debug\n    => Components tightly coupled ",
      "autoResize": true,
      "lineHeight": 1.25
    },
